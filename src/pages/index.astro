---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Koyyaka Radio">

<section>

<div class="container hero">

<p class="eyebrow">
🎙️ LIVE 24×7
</p>

<h1>
Own your<br/>
Attention.
</h1>

<p class="subtitle">
Stop Scrolling.<br/>
Start Living.
</p>

<a href="#listen" class="btn">
Listen Live
</a>

</div>

</section>

<section id="listen">

<div class="container center">

<h2>Koyyaka Radio</h2>

<p>
Tamil conversations, music and ideas designed to help people own their attention.
</p>

</div>

</section>

</Layout>

<style>
.hero{
    max-width:900px;
    margin:auto;
    text-align:center;
}

.eyebrow{
    letter-spacing:8px;
    text-transform:uppercase;
    font-size:16px;
    color:#9d9d9d;
    margin-bottom:30px;
}

.subtitle{
    margin-top:40px;
    font-size:clamp(26px,4vw,46px);
    color:#bfbfbf;
    line-height:1.3;
}

.center{
    max-width:900px;
    margin:auto;
    text-align:center;
}

.btn{
    display:inline-block;
    margin-top:60px;
    padding:18px 40px;
    background:#fff;
    color:#000;
    text-decoration:none;
    border-radius:999px;
    font-weight:700;
    font-size:20px;
}

section:first-child{
    background:radial-gradient(circle at top,#222,#000 70%);
}
</style>
