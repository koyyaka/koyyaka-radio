<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Koyyaka Radio | Own Your Attention | Ahshif Abdeen</title>

    <meta
      name="description"
      content="Koyyaka Radio is an online Tamil radio platform created by Ahshif Abdeen. Own Your Attention with meaningful conversations, music, AI, parenting and personal growth."
    />

    <meta
      name="keywords"
      content="Koyyaka, Koyyaka Radio, Ahshif Abdeen, Tamil Radio, Own Your Attention, Live Radio, Podcast"
    />

    <meta name="author" content="Ahshif Abdeen" />
    <meta name="robots" content="index, follow" />

    <link
      rel="canonical"
      href="https://koyyaka.github.io/koyyaka-radio/"
    />

    <!-- Open Graph -->
    <meta property="og:title" content="Koyyaka Radio" />
    <meta
      property="og:description"
      content="Own Your Attention. Listen to meaningful conversations and music."
    />
    <meta property="og:type" content="website" />
    <meta
      property="og:url"
      content="https://koyyaka.github.io/koyyaka-radio/"
    />
    <meta property="og:image" content="/favicon.ico" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Koyyaka Radio" />
    <meta
      name="twitter:description"
      content="Own Your Attention."
    />

    <!-- Structured Data -->
    <script type="application/ld+json">
      {
        "@context":"https://schema.org",
        "@type":"WebSite",
        "name":"Koyyaka Radio",
        "url":"https://koyyaka.github.io/koyyaka-radio/",
        "description":"Own Your Attention",
        "author":{
          "@type":"Person",
          "name":"Ahshif Abdeen"
        }
      }
    </script>

    <style>
      *{
        margin:0;
        padding:0;
        box-sizing:border-box;
      }

      html{
        scroll-behavior:smooth;
      }

      body{
        background:#000;
        color:#fff;
        font-family:-apple-system,BlinkMacSystemFont,"SF Pro Display",sans-serif;
      }

      .hero{
        min-height:100vh;
        display:flex;
        flex-direction:column;
        justify-content:center;
        align-items:center;
        text-align:center;
        padding:40px 20px;
        background:radial-gradient(circle at top,#1d1d1d 0%,#000 70%);
      }

      .live{
        color:#999;
        letter-spacing:8px;
        font-size:20px;
        margin-bottom:50px;
      }

      h1{
        font-size:clamp(56px,8vw,96px);
        line-height:1.05;
        margin-bottom:40px;
      }

      h2{
        font-size:clamp(42px,6vw,72px);
        font-weight:400;
        color:#d0d0d0;
        line-height:1.15;
      }

      .button{
        margin-top:70px;
        display:inline-block;
        background:#fff;
        color:#000;
        text-decoration:none;
        padding:22px 60px;
        border-radius:999px;
        font-size:30px;
        font-weight:700;
        transition:.25s;
      }

      .button:hover{
        transform:scale(1.04);
      }

      .about{
        padding:120px 20px;
        text-align:center;
        max-width:900px;
        margin:auto;
      }

      .about h3{
        font-size:56px;
        margin-bottom:30px;
      }

      .about p{
        color:#ccc;
        font-size:28px;
        line-height:1.7;
      }

      footer{
        padding:60px 20px;
        text-align:center;
        color:#666;
        border-top:1px solid #222;
      }

      @media(max-width:768px){

        .live{
          font-size:14px;
          letter-spacing:5px;
        }

        h1{
          font-size:54px;
        }

        h2{
          font-size:34px;
        }

        .button{
          font-size:22px;
          padding:18px 42px;
        }

        .about h3{
          font-size:40px;
        }

        .about p{
          font-size:22px;
        }

      }
    </style>

  </head>

  <body>

    <section class="hero">

      <div class="live">
        🎙 LIVE 24×7
      </div>

      <h1>
        Own your<br />
        Attention.
      </h1>

      <h2>
        Stop Scrolling.<br />
        Start Living.
      </h2>

      <a
        class="button"
        href="https://koyyaka-radio-278466263119.asia-southeast1.run.app/?station=915aba"
      >
        Listen Live
      </a>

    </section>

    <section class="about">

      <h3>Koyyaka Radio</h3>

      <p>
        Koyyaka Radio is an online Tamil radio platform created by
        Ahshif Abdeen. We share conversations, music and ideas that
        help people own their attention.
      </p>

    </section>

    <footer>
      © 2026 Koyyaka Radio • Own Your Attention
    </footer>

  </body>
</html>